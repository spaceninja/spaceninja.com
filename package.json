{
  "name": "spaceninja.com",
  "version": "10.0.0",
  "description": "",
  "author": "Scott Vandehey",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "start": "npm run watch",
    "build": "run-p build:*",
    "build:content": "eleventy",
    "build:css": "sass src:dist",
    "watch": "run-p watch:*",
    "watch:content": "eleventy --serve --quiet",
    "watch:css": "sass --watch src:dist",
    "lint": "run-s lint:js lint:css lint:prettier lint:webc",
    "lint:check": "run-s lint:js:check lint:css:check lint:prettier:check",
    "lint:js": "eslint . --fix",
    "lint:js:check": "eslint .",
    "lint:css": "stylelint --fix '**/*.scss'",
    "lint:css:check": "stylelint '**/*.scss'",
    "lint:prettier": "prettier . --write",
    "lint:prettier:check": "prettier . --check",
    "lint:webc": "prettier '**/*.webc' --write",
    "lint:webc:check": "prettier '**/*.webc' --check"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.6",
    "@11ty/eleventy-img": "6.0.4",
    "@11ty/eleventy-navigation": "1.0.5",
    "@11ty/eleventy-plugin-rss": "3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "5.0.2",
    "@11ty/eleventy-plugin-webc": "0.11.2",
    "@eslint/js": "10.0.1",
    "eleventy-plugin-time-to-read": "1.3.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "markdown-it-footnote": "4.0.0",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-spaceninja": "17.0.0"
  }
}
